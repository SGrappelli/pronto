# =================================================================
# Pronto SaaS — additional environment variables
# These are required ON TOP of the base .env.example variables
# when running in SaaS mode (NEXT_PUBLIC_DEPLOYMENT_MODE=saas).
#
# On the DigitalOcean server: copy .env.example to .env, fill in
# the base variables, then add the variables below to the same .env.
# =================================================================

# ── Root domain (required for subdomain routing) ───────────────────
NEXT_PUBLIC_ROOT_DOMAIN=trypronto.app

# ── Admin panel ─────────────────────────────────────────────────────
# Email of the admin user who can access /admin
# Anyone else gets a 404
ADMIN_EMAIL=

# ── Email sender ────────────────────────────────────────────────────
RESEND_FROM_EMAIL=Pronto <noreply@trypronto.app>

# ── Payments: Paddle ────────────────────────────────────────────────
# Used for subscription billing on trypronto.app
# Dashboard: vendors.paddle.com → Developer Tools → Authentication
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=production

# Price IDs from your Paddle catalog
# Paddle Dashboard → Catalog → Prices
PADDLE_PRICE_STARTER_MONTHLY=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_MONTHLY=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_AGENCY_MONTHLY=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_STARTER_ANNUAL=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_ANNUAL=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_AGENCY_ANNUAL=pri_xxxxxxxxxxxxxxxx

# ── Storage: Cloudflare R2 ──────────────────────────────────────────
# For user file uploads (avatars, attachments, etc.)
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pronto-uploads
R2_PUBLIC_URL=https://cdn.trypronto.app
