# Copy to .env.staging and adjust values
# NEXTAUTH_URL and NEXT_PUBLIC_APP_URL must point to staging URL

# ── Supabase ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://pdfunjbzaxjrpzoysprl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ────────────────────────────────────────────
NEXT_PUBLIC_DEPLOYMENT_MODE=saas

# IMPORTANT: must point to staging URL
NEXTAUTH_URL=https://staging.trypronto.app
NEXT_PUBLIC_APP_URL=https://staging.trypronto.app
NEXT_PUBLIC_SITE_URL=https://staging.trypronto.app

# ── Email ──────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Pronto <noreply@trypronto.app>

# ── WhatsApp (Meta Cloud API) ──────────────────────
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_access_token

# ── Cron ───────────────────────────────────────────
CRON_SECRET=change-this-secret

# ── Node ───────────────────────────────────────────
NODE_ENV=production

DATABASE_URL=postgresql://postgres.pdfunjbzaxjrpzoysprl:your_password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
INTERNAL_API_SECRET=change-this-secret
